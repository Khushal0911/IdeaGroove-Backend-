# ============================================
# Node.js & Express Backend .gitignore
# ============================================

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development
.env.test
.env.production
.env*.local

# ============================================
# Logs
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# ============================================
# OS Generated Files
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ============================================
# IDE & Editor Files
# ============================================
# VS Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Sublime Text
*.sublime-project
*.sublime-workspace

# WebStorm
.webstorm/

# ============================================
# Testing
# ============================================
coverage/
*.lcov
.nyc_output/
.grunt/
lib-cov/

# ============================================
# Build & Dist
# ============================================
dist/
build/
.cache/
.parcel-cache/
.next/
out/

# ============================================
# Database
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
# Uploads & User Generated Content
# ============================================
uploads/
temp/
tmp/
public/uploads/
public/images/uploads/
storage/

# ============================================
# SSL Certificates & Keys
# ============================================
*.pem
*.key
*.cert
*.crt
ssl/
certs/

# ============================================
# Session & Cache
# ============================================
sessions/
.cache/
*.cache

# ============================================
# Backup Files
# ============================================
*.bak
*.backup
*.swp
*.swo
*~

# ============================================
# Documentation (optional - remove if you want to track)
# ============================================
# docs/generated/

# ============================================
# Miscellaneous
# ============================================
.npm/
.eslintcache
.node_repl_history
.yarn-integrity
.pnp.*
.pnp.js

# ============================================
# Serverless
# ============================================
.serverless/
.webpack/

# ============================================
# Docker (optional - uncomment if needed)
# ============================================
# docker-compose.override.yml

# ============================================
# TypeScript (if using)
# ============================================
*.tsbuildinfo

# ============================================
# Project Specific (Add your custom files)
# ============================================
# Add any project-specific files or folders below
# Example:
# config/database.js
# scripts/seed-data.js